# Backend API origin — no trailing slash.
# The SuperTokens SDK uses this as apiDomain and all fetch calls prefix it.
# Production: https://api-production-b93e.up.railway.app
# Local dev:  http://localhost:3001  (Vite proxy maps /auth + /api for you)
VITE_API_ORIGIN=https://api-production-b93e.up.railway.app

# Sentry error tracking (wave-35). Set on Railway at deploy. Unset -> SDK no-ops.
# When set, the ingest host (parsed from the DSN, e.g. o<n>.ingest.<region>.sentry.io)
# is auto-added to the CSP connect-src at build time so error POSTs aren't blocked.
VITE_SENTRY_DSN=

# --- Build-time CSP origins (wave-84 B-6) ---------------------------------
# These are baked into the Content-Security-Policy <meta> tag at `vite build`
# time (see src/csp.ts). The web Docker build MUST pass them so the deployed SPA
# can load attachments/avatars, upload files, and connect voice WITHOUT CSP
# violations. A prod build with an empty VITE_API_ORIGIN FAILS by design.

# Tigris object-storage PUBLIC origin — scheme + host only, no bucket, no trailing slash.
# Attachments/uploads/avatars are presigned GET/PUT against this host, and the
# avatar redirect (302 from {api}/users/:id/avatar) targets it — so it is added
# to BOTH img-src and connect-src. Prod value = the AWS_ENDPOINT_URL host set on
# the api service (Tigris default: https://fly.storage.tigris.dev).
VITE_STORAGE_ORIGIN=https://fly.storage.tigris.dev

# LiveKit voice signaling wss URL — added to connect-src (voice rooms can't
# connect without it). Must equal the api service's LIVEKIT_URL (a *.livekit.cloud
# host for LiveKit Cloud, or your self-hosted LiveKit wss origin). No trailing slash.
# Example: wss://studyhall.livekit.cloud
VITE_LIVEKIT_URL=
