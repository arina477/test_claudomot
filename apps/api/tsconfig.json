{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "baseUrl": ".",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@studyhall/shared": ["../../packages/shared/src"]
    }
  },
  "references": [{ "path": "../../packages/shared" }],
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
