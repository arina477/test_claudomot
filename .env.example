# .env.example — placeholders for project env vars.
# Populated at v6b from architecture/{security,sdks,databases,services,devops}.md.
# After onboarding, B-0 Action 3 appends new placeholders per wave.
#
# DO NOT commit .env (gitignored). Generate secrets per always-on rule #6:
#   openssl rand -base64 32
# Account-issued credentials (LiveKit, Resend, Sentry, Railway) are requested
# from the founder / provider consoles, not self-generated.

# ── Database — Postgres on Railway (architecture/databases.md) ──
DATABASE_URL=postgres://user:pass@localhost:5432/studyhall_dev   # app runtime (pooled)
DATABASE_URL_UNPOOLED=postgres://user:pass@localhost:5432/studyhall_dev  # drizzle-kit migrations (direct, no pooler)
DATABASE_URL_TEST=postgres://user:pass@localhost:5432/studyhall_test     # vitest integration / CI

# ── Auth — SuperTokens self-hosted on Railway (architecture/security.md) ──
SUPERTOKENS_CONNECTION_URI=   # SuperTokens Core URL (Railway private networking)
SUPERTOKENS_API_KEY=          # SuperTokens Core API key (generated in Railway env)
SESSION_SECRET=               # app session signing secret — openssl rand -base64 32
# Session cookie: SameSite=Lax (invite-link→login→auto-redeem needs it); httpOnly; secure in prod
COOKIE_DOMAIN=                # e.g. .studyhall.app in prod; blank for localhost
API_ORIGIN=http://localhost:3000
WEB_ORIGIN=http://localhost:5173

# ── Realtime — Socket.IO (architecture/services.md) ──
# Two namespaces: /messaging (messages+typing+reactions), /presence (presence+voice occupancy).
# Auth: SuperTokens session cookie validated on WS upgrade (withCredentials);
#       short-lived JWT in handshake auth payload is the cross-origin/PWA fallback.

# ── Voice/Video — LiveKit SFU (architecture/sdks.md) — account-issued ──
LIVEKIT_URL=                  # wss://... (LiveKit Cloud) or self-hosted Railway service
LIVEKIT_API_KEY=              # from LiveKit console (or self-host config)
LIVEKIT_API_SECRET=           # from LiveKit console (or self-host config)

# ── Object storage — Railway Buckets (S3-compatible, Tigris-backed) (architecture/sdks.md) ──
# AWS_* names are required for the AWS S3 SDK default credential resolution.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=             # Railway Buckets / Tigris S3 endpoint
STORAGE_BUCKET_NAME=studyhall-uploads
# File caps enforced server-side: avatar ≤ 2 MB, attachment ≤ 10 MB

# ── Transactional email — Resend (architecture/sdks.md) — account-issued ──
# Two consumers, two keys: SuperTokens Core (verify + password-reset) and NotificationsModule (invites + reminders).
RESEND_API_KEY_AUTH=          # used by SuperTokens Core for verify/reset emails
RESEND_API_KEY_NOTIFY=        # used by NotificationsModule for invite/reminder emails
EMAIL_FROM=noreply@studyhall.app

# ── Observability — Sentry (architecture/devops.md) — add at first deploy ──
SENTRY_DSN=                   # error tracking (PII scrubbing: no email in events)

# ── Payments — Stripe — DEFERRED to H2 (architecture/sdks.md), placeholders only ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Deploy — Railway bring-your-own (architecture/devops.md) ──
# RAILWAY_TOKEN collected at deploy time (C-2 Action 0), never committed.
NODE_ENV=development

